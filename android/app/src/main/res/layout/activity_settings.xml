<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/tm_dark">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings"
        android:textColor="@color/tm_white"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/orchestrator_url"
        app:hintTextColor="@color/tm_gray"
        app:boxStrokeColor="@color/tm_red"
        app:helperText="Lambda Function URL (e.g. https://xxx.lambda-url.us-east-1.on.aws)"
        app:helperTextTextColor="@color/tm_gray"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etOrchestratorUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/tm_white"
            android:inputType="textUri" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Default Demo PC"
        app:hintTextColor="@color/tm_gray"
        app:boxStrokeColor="@color/tm_red"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDefaultDemoPc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/tm_white"
            android:text="booth-pc-1"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Default SE Name"
        app:hintTextColor="@color/tm_gray"
        app:boxStrokeColor="@color/tm_red"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDefaultSeName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/tm_white"
            android:inputType="textPersonName" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="AWS Access Key ID"
        app:hintTextColor="@color/tm_gray"
        app:boxStrokeColor="@color/tm_red"
        app:helperText="For S3 badge photo upload"
        app:helperTextTextColor="@color/tm_gray"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etAwsAccessKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/tm_white"
            android:inputType="textVisiblePassword" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="AWS Secret Access Key"
        app:hintTextColor="@color/tm_gray"
        app:boxStrokeColor="@color/tm_red"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:endIconMode="password_toggle">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etAwsSecretKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/tm_white"
            android:inputType="textPassword" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="@string/save"
        app:backgroundTint="@color/tm_red"
        app:cornerRadius="12dp" />

</LinearLayout>
