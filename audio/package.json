{
  "name": "boothapp-audio",
  "version": "1.0.0",
  "description": "BoothApp audio recorder — session-triggered ffmpeg capture for trade show demos",
  "main": "recorder.js",
  "scripts": {
    "start": "node recorder.js",
    "list-devices": "node -e \"require('./lib/device-detect').listDevices().then(d => d.forEach(x => console.log(x))).catch(e => { console.error(e.message); process.exit(1); })\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "os": ["win32"],
  "keywords": ["audio", "ffmpeg", "dshow", "recording", "aws-s3"]
}
