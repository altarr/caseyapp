{
  "manifest_version": 3,
  "name": "CaseyApp",
  "version": "2.0.0",
  "description": "CaseyApp demo capture: screenshots, audio recording, and click tracking for AI-powered follow-up.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "offscreen"
  ],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "V1-Helper"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
